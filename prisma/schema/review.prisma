model Review {
  id           String @id @default(uuid()) @db.Uuid
  bookingId    String @unique @map("booking_id") @db.Uuid
  customerId   String @map("customer_id") @db.Uuid
  technicianId String @map("technician_id") @db.Uuid
  serviceId    String @map("service_id") @db.Uuid

  rating  Int           @db.SmallInt
  comment String?       @db.Text
  status  TReviewStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  booking    Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer   CustomerProfile   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  service    Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@index([serviceId])
  @@index([status])
  @@map("reviews")
}
