model AvailabilitySlot {
  id String @id @default(uuid()) @db.Uuid

  technicianId String @map("technician_id") @db.Uuid

  dayOfWeek TDayOfWeek @map("day_of_week")

  startTime DateTime @map("start_time")

  endTime DateTime @map("end_time")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([technicianId, dayOfWeek, startTime, endTime])
  @@index([technicianId])
  @@map("availability_slots")
}
